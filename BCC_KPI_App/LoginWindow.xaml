<Window x:Class="BCC_KPI_App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему BCC KPI" 
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <TextBlock Text="🏭 BCC KPI" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Text="Логин:" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
        <TextBox Grid.Row="2" x:Name="txtUsername" Height="35" Padding="10" FontSize="14" 
                 BorderBrush="#BDC3C7" BorderThickness="1" Background="White"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="txtPassword" Height="35" Padding="10" FontSize="14" 
                     BorderBrush="#BDC3C7" BorderThickness="1" Background="White"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25">
            <Button Content="🔓 ВОЙТИ" Click="Login_Click" Background="#3498DB" Foreground="White" 
                    Padding="35,12" Margin="5" Cursor="Hand" FontWeight="Bold" FontSize="14"/>
            <Button Content="❌ ВЫХОД" Click="Cancel_Click" Background="#E74C3C" Foreground="White" 
                    Padding="35,12" Margin="5" Cursor="Hand" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <TextBlock Grid.Row="6" x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" 
                   FontSize="12" Margin="0,10" Visibility="Collapsed"/>

        <TextBlock Grid.Row="7" Text="admin / admin123" 
                   Foreground="#7F8C8D" FontSize="10" HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>