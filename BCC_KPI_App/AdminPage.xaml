<Page x:Class="BCC_KPI_App.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewModels="clr-namespace:BCC_KPI_App.ViewModels"
      Title="AdminPage"
      Background="#F5F5F5">

    <Page.DataContext>
        <viewModels:AdminViewModel />
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление подразделениями" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Units}"
                  SelectedItem="{Binding SelectedUnit}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderThickness="0"
                  RowHeight="40"
                  FontSize="14">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" 
                                    Binding="{Binding UnitName}" 
                                    Width="*"/>
                <DataGridTextColumn Header="Тип" 
                                    Binding="{Binding UnitType}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding Status}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Город" 
                                    Binding="{Binding City}" 
                                    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>