<Page x:Class="BCC_KPI_App.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewModels="clr-namespace:BCC_KPI_App.ViewModels"
      Title="ReportsPage"
      Background="#F5F5F5">

    <Page.DataContext>
        <viewModels:ReportsViewModel />
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="📋 Отчеты" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,20"
                BorderBrush="#BDC3C7"
                BorderThickness="1">
            <WrapPanel>
                <TextBlock Text="Период:" VerticalAlignment="Center" Margin="10,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="150" Margin="5"/>
                <TextBlock Text="—" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="150" Margin="5"/>
                <Button Content="📊 Сформировать" 
                        Command="{Binding GenerateReportCommand}"
                        Background="#3498DB"
                        Foreground="White"
                        Padding="15,8"
                        Margin="20,0"
                        Cursor="Hand"/>
                <Button Content="📥 Excel" 
                        Command="{Binding ExportToExcelCommand}"
                        Background="#27AE60"
                        Foreground="White"
                        Padding="15,8"
                        Margin="5,0"
                        Cursor="Hand"/>
                <Button Content="📥 PDF" 
                        Command="{Binding ExportToPdfCommand}"
                        Background="#E74C3C"
                        Foreground="White"
                        Padding="15,8"
                        Margin="5,0"
                        Cursor="Hand"/>
            </WrapPanel>
        </Border>

        <ListView Grid.Row="2" 
                  ItemsSource="{Binding ReportData}"
                  Background="White"
                  BorderThickness="1"
                  BorderBrush="#BDC3C7">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Подразделение" Width="200" DisplayMemberBinding="{Binding Подразделение}"/>
                    <GridViewColumn Header="План" Width="150" DisplayMemberBinding="{Binding План, StringFormat=N0}"/>
                    <GridViewColumn Header="Факт" Width="150" DisplayMemberBinding="{Binding Факт, StringFormat=N0}"/>
                    <GridViewColumn Header="Выполнение" Width="150" DisplayMemberBinding="{Binding Выполнение}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>