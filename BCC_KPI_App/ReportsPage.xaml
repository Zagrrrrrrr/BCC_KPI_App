<Page x:Class="BCC_KPI_App.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewModels="clr-namespace:BCC_KPI_App.ViewModels"
      Title="ReportsPage"
      Background="#F5F5F5">

    <Page.DataContext>
        <viewModels:ReportsViewModel />
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Отчеты по продажам" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <!-- Фильтры -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,20"
                Effect="{StaticResource ShadowEffect}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Период:" VerticalAlignment="Center" Margin="10,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Margin="5" Width="150"/>
                <TextBlock Text="-" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding EndDate}" Margin="5" Width="150"/>
                <Button Content="Сформировать" 
                        Command="{Binding GenerateReportCommand}"
                        Background="#3498DB"
                        Foreground="White"
                        Padding="15,8"
                        Margin="20,0,0,0"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица с отчетом -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding ReportData}"
                  AutoGenerateColumns="True"
                  Background="White"
                  BorderThickness="0"
                  RowHeight="40"
                  FontSize="14"/>
    </Grid>
</Page>