<Page x:Class="BCC_KPI_App.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:viewModels="clr-namespace:BCC_KPI_App.ViewModels"
      Title="DashboardPage"
      Background="#F5F5F5">

    <Page.DataContext>
        <viewModels:DashboardViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <!-- Заголовок -->
            <TextBlock Text="📊 Панель мониторинга KPI" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       Margin="0,0,0,20"/>

            <!-- Фильтры -->
            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="20" 
                    Margin="0,0,0,20"
                    BorderBrush="#BDC3C7"
                    BorderThickness="1">
                <WrapPanel>
                    <TextBlock Text="Период:" 
                              FontSize="14" 
                              FontWeight="Bold"
                              VerticalAlignment="Center"
                              Margin="10,0"/>

                    <DatePicker SelectedDate="{Binding StartDate}" 
                               Width="150" 
                               Margin="5"/>

                    <TextBlock Text="—" 
                              VerticalAlignment="Center"
                              Margin="5"/>

                    <DatePicker SelectedDate="{Binding EndDate}" 
                               Width="150" 
                               Margin="5"/>

                    <Button Content="Применить" 
                            Command="{Binding ApplyFilterCommand}"
                            Background="#3498DB"
                            Foreground="White"
                            Padding="15,8"
                            Margin="20,0"
                            Cursor="Hand"/>

                    <Button Content="📊 Сравнить" 
                            Command="{Binding CompareCommand}"
                            Background="#F39C12"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            Cursor="Hand"/>

                    <Button Content="📥 Экспорт" 
                            Command="{Binding ExportCommand}"
                            Background="#27AE60"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            Cursor="Hand"/>
                </WrapPanel>
            </Border>

            <!-- Карточки с итогами -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="5"
                        BorderBrush="#3498DB"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="Общий план" 
                                  FontSize="14" 
                                  Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding TotalTarget, StringFormat=N0}" 
                                  FontSize="24" 
                                  FontWeight="Bold" 
                                  Foreground="#3498DB"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="5"
                        BorderBrush="#2ECC71"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="Общий факт" 
                                  FontSize="14" 
                                  Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding TotalActual, StringFormat=N0}" 
                                  FontSize="24" 
                                  FontWeight="Bold" 
                                  Foreground="#27AE60"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="5"
                        BorderBrush="#F39C12"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="Выполнение" 
                                  FontSize="14" 
                                  Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding TotalPercentage}" 
                                  FontSize="24" 
                                  FontWeight="Bold" 
                                  Foreground="#F39C12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="5"
                        BorderBrush="#9B59B6"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="Кол-во подразделений" 
                                  FontSize="14" 
                                  Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding UnitsCount}" 
                                  FontSize="24" 
                                  FontWeight="Bold" 
                                  Foreground="#9B59B6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- График сравнения плана и факта -->
            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="20"
                    Margin="0,0,0,20"
                    BorderBrush="#BDC3C7"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                              Text="📊 Сравнение плана и факта по подразделениям" 
                              FontSize="18" 
                              FontWeight="Bold"
                              Foreground="#2C3E50"
                              Margin="0,0,0,15"/>

                    <lvc:CartesianChart Grid.Row="1" Series="{Binding ComparisonSeries}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Подразделения" 
                                      Labels="{Binding UnitNames}"
                                      FontSize="12"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Сумма (руб)" 
                                      LabelFormatter="{Binding Formatter}"
                                      FontSize="12"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <!-- Таблица детализации -->
            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="20"
                    BorderBrush="#BDC3C7"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                              Text="📋 Детализация по подразделениям" 
                              FontSize="18" 
                              FontWeight="Bold"
                              Foreground="#2C3E50"
                              Margin="0,0,0,15"/>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding ChartData}"
                              Background="Transparent"
                              BorderThickness="0"
                              Height="300">

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Подразделение" 
                                                Width="250" 
                                                DisplayMemberBinding="{Binding UnitName}"/>

                                <GridViewColumn Header="План (руб)" 
                                                Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TargetValue, StringFormat=N0}" 
                                                       HorizontalAlignment="Right"
                                                       FontWeight="Bold"
                                                       Foreground="#3498DB"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Факт (руб)" 
                                                Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ActualValue, StringFormat=N0}" 
                                                       HorizontalAlignment="Right"
                                                       FontWeight="Bold"
                                                       Foreground="#27AE60"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Выполнение" 
                                                Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CompletionPercentage, StringFormat={}{0:0}%}" 
                                                       HorizontalAlignment="Right"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#2C3E50"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>